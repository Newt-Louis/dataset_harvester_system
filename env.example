# https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxx"

# https://console.groq.com/keys
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxx"

# https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIzaSyxxxxxxxxxxxxxxxxxxxx"

# https://dashboard.cohere.com/api-keys
COHERE_API_KEY="xxxxxxxxxxxxxxxxxxxx"

MAX_CONCURRENT_REQUESTS=5
TIMEOUT_SECONDS=60
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# if production use this command: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-long-random-string
# if production use this command: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-fernet-key

DATABASE_URL='if_sqlite_remove_this_value'

# Google drive storage
GDRIVE_FOLDER_ID=your_folder_id_here
GDRIVE_CREDENTIALS_PATH=gdrive_credentials.json

# S3 like Cloudflare R2, AWS S3, etc...
S3_ENDPOINT=https://xxxxxx.r2.cloudflarestorage.com
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=my-ai-datasets
S3_PUBLIC_URL=https://pub-xxxxxx.r2.dev